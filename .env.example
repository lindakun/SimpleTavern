# SimpleTavern 环境变量模板
# 复制此文件为 .env 并填写实际值

# ============================================
# 后端配置 (backend/.env)
# ============================================

# 服务端口
PORT=8001

# 数据目录（本地开发指向 SillyTavern 数据）
SIMPLE_TAVERN_DATA_ROOT=/Users/linda/code/SillyTavern/data

# Google OAuth 配置（必需用于 Google 登录）
# 从 Google Cloud Console 获取: https://console.cloud.google.com/
SIMPLE_TAVERN_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SIMPLE_TAVERN_GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# LLM 配置 — 支持多 LLM，通过序号 0,1,2... 扩展
SIMPLE_TAVERN_LLM_0_BASE_URL=https://api.openai.com/v1
SIMPLE_TAVERN_LLM_0_MODEL=gpt-4o
SIMPLE_TAVERN_LLM_0_API_KEY=sk-your-api-key
SIMPLE_TAVERN_LLM_0_NAME=OpenAI

# 可选：第二个 LLM 提供商
# SIMPLE_TAVERN_LLM_1_BASE_URL=http://localhost:1234/v1
# SIMPLE_TAVERN_LLM_1_MODEL=local-model
# SIMPLE_TAVERN_LLM_1_API_KEY=sk-local
# SIMPLE_TAVERN_LLM_1_NAME=Local

# 默认使用的 LLM ID（留空用第一个）
SIMPLE_TAVERN_ACTIVE_LLM=llm_0

# ============================================
# 前端配置 (frontend/.env)
# ============================================

# Google OAuth Client ID（与后端相同）
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
